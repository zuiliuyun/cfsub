/*
 * Cloudflare Worker: 最终稳定实时订阅生成器 (全协议保留 + Token 安全版)
 */

const REPO = "zuiliuyun/IOP"; // [cite: 1]
const FILES = ["domain", "addressesapi.txt"]; // [cite: 1]

/* ========= 多协议模板 (支持 VMESS/VLESS/TROJAN) ========= */
const NODE_TEMPLATES = [
  // VMESS [cite: 2]
  "vmess://",
  // VLESS (取消注释即可启用) [cite: 2]
  //"vless://uuid@test.com:443?encryption=none&security=tls&type=ws&host=test.com&sni=test.com#test",
  // TROJAN (取消注释即可启用) [cite: 2]
  //"trojan://password@test.com:443?security=tls&type=ws&host=test.com&sni=test.com#test"
];

/* ========= 原始工具函数 ========= */
function isIP(host) { return /^(\d{1,3}\.){3}\d{1,3}$/.test(host); } // [cite: 3]
function isValidIP(ip) { return isIP(ip) && ip.split(".").every(n => n >= 0 && n <= 255); } // [cite: 4]
function clean(line) { return line.trim().replace(/[,|]/g, " ").replace(/\s+/g, " "); } // [cite: 5]

/* ========= 实时抓取核心 ========= */
async function fetchGitHubFile(path) {
  const apiUrl = `https://api.github.com/repos/${REPO}/contents/${path}`; // [cite: 6]
  const rawUrl = `https://raw.githubusercontent.com/${REPO}/main/${path}`; // [cite: 6]

  try {
    const res = await fetch(apiUrl, {
      headers: {
        "User-Agent": "Cloudflare-Worker",
        "Accept": "application/vnd.github.v3+json",
        "Cache-Control": "no-cache"
      },
      cf: { cacheTtl: 0 }
    }); // [cite: 7]
    const json = await res.json(); // [cite: 8]
    if (json.content) return atob(json.content.replace(/\n/g, "")); // [cite: 8]
  } catch (e) { console.log("API失败:", path); }

  try {
    const res = await fetch(rawUrl + "?t=" + Date.now(), {
      headers: { "Cache-Control": "no-cache" },
      cf: { cacheTtl: 0 }
    }); // [cite: 10]
    return await res.text(); // [cite: 11]
  } catch (e) { return ""; }
}

/* ========= 强解析逻辑 (IP/域名/端口/标签) ========= */
function parse(text) {
  let result = [];
  let seen = new Set(); // [cite: 12]
  for (let raw of text.split("\n")) { // [cite: 13]
    let line = clean(raw);
    if (!line) continue;
    let tag = null;
    if (line.includes("#")) {
      let tmp = line.split("#");
      line = tmp[0];
      tag = tmp[1]?.toUpperCase(); // [cite: 14]
    }
    let host = null, port = "443";
    for (let part of line.split(" ")) { // [cite: 16]
      if (part.includes(":")) {
        let [h, p] = part.split(":");
        if (isValidIP(h) || /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(h)) {
          host = h; if (p) port = p; // [cite: 17-18]
        }
      } else if (isValidIP(part) || /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(part)) {
        host = part; // [cite: 18]
      } else if (/^\d+$/.test(part)) {
        port = part; // [cite: 19]
      }
    }
    if (!host) continue;
    let key = `${host}:${port}`;
    if (!seen.has(key)) {
      seen.add(key);
      result.push({ host, port, tag }); // [cite: 21]
    }
  }
  return result;
}

/* ========= 编码与协议处理 ========= */
function b64Encode(str) { return btoa(String.fromCharCode(...new TextEncoder().encode(str))); } // [cite: 22]
function b64Decode(str) { return new TextDecoder().decode(Uint8Array.from(atob(str), c => c.charCodeAt(0))); } // [cite: 23]
function decodeVmess(link) { return JSON.parse(b64Decode(link.replace("vmess://", ""))); } // [cite: 23]
function encodeVmess(obj) { return "vmess://" + b64Encode(JSON.stringify(obj)); } // [cite: 24]
function getName(item) { return item.tag || (isIP(item.host) ? "优选节点" : "优选域名"); } // [cite: 24-25]

/* ========= 主生成逻辑 (完全还原 VLESS/TROJAN 处理) ========= */
async function generate() {
  const texts = await Promise.all(FILES.map(f => fetchGitHubFile(f))); // [cite: 25]
  const addrList = parse(texts.join("\n")); // [cite: 26]
  let results = [];

  for (const tpl of NODE_TEMPLATES) {
    if (tpl.startsWith("vmess://")) {
      const base = decodeVmess(tpl); // [cite: 27]
      const { host: lockHost, sni: lockSni } = base; // [cite: 28]
      addrList.forEach(item => {
        let obj = { ...base, add: item.host, port: parseInt(item.port), host: lockHost, sni: lockSni, ps: getName(item) };
        results.push(encodeVmess(obj)); // [cite: 28]
      });
    } else {
      // 完全还原原始 VLESS/TROJAN URL 处理逻辑 [cite: 29-31]
      const u = new URL(tpl);
      const lockHost = u.searchParams.get("host"); // 
      const lockSni = u.searchParams.get("sni"); // 

      addrList.forEach(item => {
        const newUrl = new URL(tpl); // 
        newUrl.hostname = item.host; // 
        newUrl.port = item.port; // 
        if (lockHost) newUrl.searchParams.set("host", lockHost); // 
        if (lockSni) newUrl.searchParams.set("sni", lockSni); // 
        newUrl.hash = getName(item); // 
        results.push(newUrl.toString()); // 
      });
    }
  }
  return b64Encode(results.join("\n")); // [cite: 31]
}

/* ========= 严格验证入口 ========= */
export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    const userToken = url.searchParams.get('token');

    // 只有当环境变量 AUTH_TOKEN 存在且匹配时才允许访问
    if (!env.AUTH_TOKEN || userToken !== env.AUTH_TOKEN) {
      return new Response("Unauthorized: Access Denied", { 
        status: 403, 
        headers: { "Content-Type": "text/plain; charset=utf-8" } 
      });
    }

    try {
      const body = await generate(); // [cite: 31]
      return new Response(body, {
        headers: {
          "Content-Type": "text/plain; charset=utf-8",
          "Cache-Control": "no-store, no-cache"
        }
      }); // [cite: 32]
    } catch (e) {
      return new Response("Error: " + e.message, { status: 500 });
    }
  }
};
