/*
 * Cloudflare Worker: 最终稳定实时订阅生成器
 */

const REPO = "zuiliuyun/IOP";

const FILES = [
  "domain",
  "addressesapi.txt"
];

/* ========= 多协议模板 ========= */

const NODE_TEMPLATES = [

  // VMESS
  "vmess://ewogICJ2IjogIjIiLAogICJwcyI6ICJ0ZXN0IiwKICAiYWRkIjogInRlc3QuY29tIiwKICAicG9ydCI6ICI0NDMiLAogICJpZCI6ICJhYmMiLAogICJuZXQiOiAid3MiLAogICJ0bHMiOiAidGxzIiwKICAiaG9zdCI6ICJ0ZXN0LmNvbSIsCiAgInNuaSI6ICJ0ZXN0LmNvbSIKfQ==",

  // VLESS
  //"vless://uuid@test.com:443?encryption=none&security=tls&type=ws&host=test.com&sni=test.com#test",

  // TROJAN
  //"trojan://password@test.com:443?security=tls&type=ws&host=test.com&sni=test.com#test"
];

/* ========= 工具 ========= */

function isIP(host) {
  return /^(\d{1,3}\.){3}\d{1,3}$/.test(host);
}

function isValidIP(ip) {
  return isIP(ip) && ip.split(".").every(n => n >= 0 && n <= 255);
}

function clean(line) {
  return line.trim().replace(/[,|]/g, " ").replace(/\s+/g, " ");
}

/* ========= 实时抓取（核心） ========= */

async function fetchGitHubFile(path) {

  const apiUrl = `https://api.github.com/repos/${REPO}/contents/${path}`;
  const rawUrl = `https://raw.githubusercontent.com/${REPO}/main/${path}`;

  // ===== API（实时）=====
  try {
    const res = await fetch(apiUrl, {
      headers: {
        "User-Agent": "Cloudflare-Worker",
        "Accept": "application/vnd.github.v3+json",
        "Cache-Control": "no-cache"
      },
      cf: { cacheTtl: 0 }
    });

    const json = await res.json();

    if (json.content) {
      console.log("✅ API:", path);
      return atob(json.content.replace(/\n/g, ""));
    }
  } catch (e) {
    console.log("API失败:", path);
  }

  // ===== fallback raw =====
  try {
    const res = await fetch(rawUrl + "?t=" + Date.now(), {
      headers: { "Cache-Control": "no-cache" },
      cf: { cacheTtl: 0 }
    });

    console.log("⚠️ RAW:", path);

    return await res.text();
  } catch (e) {
    console.log("RAW失败:", path);
  }

  return "";
}

/* ========= 强解析 ========= */

function parse(text) {

  let result = [];
  let seen = new Set();

  for (let raw of text.split("\n")) {

    let line = clean(raw);
    if (!line) continue;

    let tag = null;

    if (line.includes("#")) {
      let tmp = line.split("#");
      line = tmp[0];
      tag = tmp[1]?.toUpperCase();
    }

    let host = null;
    let port = "443";

    for (let part of line.split(" ")) {

      if (part.includes(":")) {
        let [h, p] = part.split(":");

        if (isValidIP(h) || /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(h)) {
          host = h;
          if (p) port = p;
        }
      }

      else if (isValidIP(part) || /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(part)) {
        host = part;
      }

      else if (/^\d+$/.test(part)) {
        port = part;
      }
    }

    if (!host) continue;

    let key = `${host}:${port}`;
    if (!seen.has(key)) {
      seen.add(key);
      result.push({ host, port, tag });
    }
  }

  return result;
}

/* ========= 编码 ========= */

function b64Encode(str) {
  return btoa(String.fromCharCode(...new TextEncoder().encode(str)));
}

function b64Decode(str) {
  return new TextDecoder().decode(Uint8Array.from(atob(str), c => c.charCodeAt(0)));
}

function decodeVmess(link) {
  return JSON.parse(b64Decode(link.replace("vmess://", "")));
}

function encodeVmess(obj) {
  return "vmess://" + b64Encode(JSON.stringify(obj));
}

/* ========= 名称规则 ========= */

function getName(item) {
  if (item.tag) return item.tag;
  return isIP(item.host) ? "优选节点" : "优选域名";
}

/* ========= 主逻辑 ========= */

async function generate() {

  const texts = await Promise.all(
    FILES.map(f => fetchGitHubFile(f))
  );

  const fullText = texts.join("\n");

  console.log("总长度:", fullText.length);

  const addrList = parse(fullText);

  console.log("节点数:", addrList.length);

  let results = [];

  for (const tpl of NODE_TEMPLATES) {

    // ===== VMESS =====
    if (tpl.startsWith("vmess://")) {

      const base = decodeVmess(tpl);
      const lockHost = base.host;
      const lockSni = base.sni;

      addrList.forEach(item => {

        let obj = { ...base };

        obj.add = item.host;
        obj.port = parseInt(item.port);

        obj.host = lockHost;
        obj.sni = lockSni;

        obj.ps = getName(item);

        results.push(encodeVmess(obj));
      });
    }

    // ===== VLESS / TROJAN =====
    else {

      const u = new URL(tpl);

      const lockHost = u.searchParams.get("host");
      const lockSni = u.searchParams.get("sni");

      addrList.forEach(item => {

        const newUrl = new URL(tpl);

        newUrl.hostname = item.host;
        newUrl.port = item.port;

        if (lockHost) newUrl.searchParams.set("host", lockHost);
        if (lockSni) newUrl.searchParams.set("sni", lockSni);

        newUrl.hash = getName(item);

        results.push(newUrl.toString());
      });
    }
  }

  return b64Encode(results.join("\n"));
}

/* ========= 入口 ========= */

export default {
  async fetch() {

    const body = await generate();

    return new Response(body, {
      headers: {
        "Content-Type": "text/plain",
        "Cache-Control": "no-store, no-cache"
      }
    });
  }
};
