/**
 * Cloudflare Worker: 多协议订阅生成器（强制锁定 HOST/SNI 版）
 */

const GITHUB_RAW_URL = "https://raw.githubusercontent.com/zuiliuyun/IOP/refs/heads/main/addressesapi.txt";

const NODE_TEMPLATES = [
  "vmess://",
  "vless://",
  "trojan://"
];

function safeBase64Encode(str) {
  return btoa(unescape(encodeURIComponent(str)));
}

function encodeVmess(obj) {
  return "vmess://" + safeBase64Encode(JSON.stringify(obj));
}

function decodeVmess(link) {
  const raw = link.replace("vmess://", "");
  return JSON.parse(decodeURIComponent(escape(atob(raw))));
}

export default {
  async fetch() {
    try {
      const resp = await fetch(GITHUB_RAW_URL);
      const text = await resp.text();

      const regex = /((?:\d{1,3}\.){3}\d{1,3}|(?:[a-zA-Z0-9-]+\.)+[a-zA-Z]{2,})(?::(\d+))?/g;
      let matches = [...text.matchAll(regex)];
      
      if (matches.length === 0) return new Response("未找到地址", { status: 404 });

      let addrList = [];
      let seen = new Set();
      for (let m of matches) {
        let key = m[1] + ":" + (m[2] || "443");
        if (!seen.has(key)) {
          seen.add(key);
          addrList.push({ host: m[1], port: m[2] });
        }
      }

      let results = [];

      for (let tpl of NODE_TEMPLATES) {
        // ================= VMESS 处理 =================
        if (tpl.startsWith("vmess://")) {
          let baseObj = decodeVmess(tpl);
          // 预存原始 host 和 sni
          const lockHost = baseObj.host;
          const lockSni = baseObj.sni;

          addrList.forEach((item, i) => {
            let obj = { ...baseObj };
            obj.add = item.host;
            if (item.port) obj.port = item.port;
            
            // 强制还原，防止被 item.host 误导
            obj.host = lockHost;
            obj.sni = lockSni;
            obj.ps = `VMESS_${i + 1}`;
            results.push(encodeVmess(obj));
          });
        } 
        // ================= VLESS / TROJAN 处理 =================
        else if (tpl.startsWith("vless://") || tpl.startsWith("trojan://")) {
          const reg = /^(vless|trojan):\/\/([^@]+)@([^:]+):([^?#]+)(\?[^#]*)?(#.*)?$/;
          let parts = tpl.match(reg);
          if (!parts) continue;

          let protocol = parts[1];
          let auth = parts[2];
          let params = parts[5] || ""; // 这里包含了原始的 sni 和 host 参数

          addrList.forEach((item, i) => {
            let port = item.port || parts[4];
            // 拼接时保留原有的 params（即保留了原始 sni/host）
            results.push(`${protocol}://${auth}@${item.host}:${port}${params}#${protocol.toUpperCase()}_${i + 1}`);
          });
        }
      }

      let finalBase64 = safeBase64Encode(results.join("\n"));
      return new Response(finalBase64, {
        headers: { "Content-Type": "text/plain; charset=utf-8", "Access-Control-Allow-Origin": "*" }
      });

    } catch (e) {
      return new Response("错误: " + e.message);
    }
  }
};
