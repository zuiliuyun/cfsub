/**
 * Cloudflare Worker: 全协议订阅生成器 (稳定版)
 * 功能：定时抓取优选IP，锁定节点 Host/SNI 参数，支持多协议 [cite: 1, 2, 3]
 * KV 绑定 (必做)：在 Cloudflare 控制台的 Settings -> Variables 下，添加 KV Namespace Binding。变量名称必须为 SUBSCRIBES
 * Cron 设置 (必做)：在 Triggers 选项卡下添加定时任务。为了保证您的订阅有效且不频繁报错，建议设置为 */10 * * * * (每 10 分钟一次)
 */
/**
 * Cloudflare Worker: 自动国家标签识别订阅生成器
 * 支持：根据 IP 后缀 (#JP, #US 等) 自动命名
 */
const SOURCES = [
  "https://raw.githubusercontent.com/zuiliuyun/IOP/refs/heads/main/domain",
  "https://raw.githubusercontent.com/zuiliuyun/IOP/refs/heads/main/addressesapi.txt"
];

const NODE_TEMPLATES = [
  "vmess://"
  "vless://"
  "trojan://"
];

// 国家代码对照表
const COUNTRY_MAP = {
  "JP": "日本",
  "US": "美国",
  "HK": "香港",
  "SG": "新加坡",
  "KR": "韩国",
  "TW": "台湾",
  "CN": "中国",
  "GB": "英国",
  "DE": "德国"
};

/* ========= 核心处理逻辑 ========= */
async function processAndCache(env) {
  try {
    const text = await fetchAllSources();
    
    // 升级正则：捕获 IP/域名、端口(可选) 以及其后的 #标签(可选)
    // 匹配格式如: 1.1.1.1:443#JP 或 1.1.1.1#US
    const regex = /((?:\d{1,3}\.){3}\d{1,3}|(?:[a-zA-Z0-9-]+\.)+[a-zA-Z]{2,})(?::(\d+))?(?:#([a-zA-Z]+))?/g;

    let addrList = [];
    let seen = new Set();

    for (const m of text.matchAll(regex)) {
      const host = m[1];
      const port = m[2] || "443";
      const tag = m[3] ? m[3].toUpperCase() : null; // 捕获到的 JP, US 等
      
      if (!host || host.includes("..")) continue;
      const key = `${host}:${port}`;
      if (!seen.has(key)) {
        seen.add(key);
        addrList.push({ host, port, tag });
      }
    }

    let results = [];
    for (const tpl of NODE_TEMPLATES) {
      if (tpl.startsWith("vmess://")) {
        const base = decodeVmess(tpl);
        const lockHost = base.host;
        const lockSni = base.sni;

        addrList.forEach((item, i) => {
          let obj = { ...base };
          obj.add = item.host;
          obj.port = parseInt(item.port, 10);
          obj.host = lockHost;
          obj.sni = lockSni;
          
          // 确定国家名称
          const countryName = COUNTRY_MAP[item.tag] || "优选节点";
          obj.ps = `${countryName}_VMESS_${i + 1}`;
          
          results.push(encodeVmess(obj));
        });
      } else if (tpl.startsWith("vless://") || tpl.startsWith("trojan://")) {
        const u = new URL(tpl);
        const protocol = u.protocol.replace(":", "").toUpperCase();
        const lockSni = u.searchParams.get("sni");
        const lockHost = u.searchParams.get("host");

        addrList.forEach((item, i) => {
          const newUrl = new URL(tpl);
          newUrl.hostname = item.host;
          newUrl.port = item.port;
          if (lockSni) newUrl.searchParams.set("sni", lockSni);
          if (lockHost) newUrl.searchParams.set("host", lockHost);
          
          const countryName = COUNTRY_MAP[item.tag] || "优选节点";
          newUrl.hash = `${countryName}_${protocol}_${i + 1}`;
          results.push(newUrl.toString());
        });
      }
    }

    const finalBody = b64Encode(results.join("\n"));
    if (env && env.SUBSCRIBES) {
      await env.SUBSCRIBES.put("CACHE_BASE64", finalBody);
    }
    return finalBody;
  } catch (err) {
    return "Error: " + err.message;
  }
}

/* ========= 工具函数 ========= */
function b64Encode(str) { return btoa(String.fromCharCode(...new TextEncoder().encode(str))); }
function b64Decode(str) { return new TextDecoder().decode(Uint8Array.from(atob(str), c => c.charCodeAt(0))); }
function decodeVmess(link) { return JSON.parse(b64Decode(link.replace("vmess://", ""))); }
function encodeVmess(obj) { return "vmess://" + b64Encode(JSON.stringify(obj)); }

async function fetchAllSources() {
  const res = await Promise.allSettled(SOURCES.map(url => fetch(url).then(r => r.text())));
  return res.filter(r => r.status === "fulfilled").map(r => r.value).join("\n");
}

/* ========= 入口导出 ========= */
export default {
  // 定时任务 (Cron)
  async scheduled(event, env, ctx) {
    ctx.waitUntil(processAndCache(env));
  },

  // HTTP 请求 (fetch)
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    if (!env.SUBSCRIBES) return new Response("KV 绑定缺失: SUBSCRIBES", { status: 500 });

    let body = await env.SUBSCRIBES.get("CACHE_BASE64");

    // 智能刷新逻辑：有请求时后台悄悄更新，保证随用随新
    if (!body || url.searchParams.get("refresh") === "true") {
      body = await processAndCache(env);
    } else {
      ctx.waitUntil(processAndCache(env));
    }

    return new Response(body, {
      headers: {
        "Content-Type": "text/plain;charset=utf-8",
        "Access-Control-Allow-Origin": "*"
      }
    });
  }
};
